# Keycloak auth (required)
EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8080
EXPO_PUBLIC_KEYCLOAK_REALM=blitzpay
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=blitzpay-merchant-spa

# Skip Keycloak entirely for demos
EXPO_PUBLIC_AUTH_BYPASS=false

# Backend API
EXPO_PUBLIC_API_URL=https://api-blitzpay-staging.elegantsoftware.de

# Fire OS / no-GMS testing: expo-location uses FusedLocationProvider (GMS-only) and always
# returns null on Fire OS. Set these to hardcoded coords to bypass location resolution entirely.
# Remove or leave blank on real devices with GMS.
# EXPO_PUBLIC_MOCK_LAT=48.8566
# EXPO_PUBLIC_MOCK_LNG=2.3522