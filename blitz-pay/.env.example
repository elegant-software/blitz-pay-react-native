# Keycloak auth (required)
EXPO_PUBLIC_KEYCLOAK_URL=http://localhost:8080
EXPO_PUBLIC_KEYCLOAK_REALM=blitzpay
EXPO_PUBLIC_KEYCLOAK_CLIENT_ID=blitzpay-spa

# Skip Keycloak entirely for demos / local dev
EXPO_PUBLIC_AUTH_BYPASS=false

# Backend API
EXPO_PUBLIC_API_URL=http://localhost:3001

# TrueLayer (bank payments)
EXPO_PUBLIC_TRUELAYER_PAYMENTS_URL=https://api-blitzpay-staging.elegantsoftware.de/v1/payments/request
EXPO_PUBLIC_TRUELAYER_ENVIRONMENT=sandbox
EXPO_PUBLIC_TRUELAYER_REDIRECT_SCHEME=blitzpay
EXPO_PUBLIC_TRUELAYER_REDIRECT_HOST=payments
EXPO_PUBLIC_TRUELAYER_COUNTRY_CODE=GB

# Stripe (card payments) — publishable key only (starts with pk_)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Braintree Cardinal Commerce Maven repo — required for Android builds
# Public SDK credentials from Braintree docs (safe to commit for open-source projects)
BRAINTREE_MAVEN_USERNAME=braintree_team_sdk
BRAINTREE_MAVEN_PASSWORD=replace_me

# Mobile observability (optional)
EXPO_PUBLIC_OBSERVABILITY_ENABLED=false
EXPO_PUBLIC_OBSERVABILITY_ENVIRONMENT=development
EXPO_PUBLIC_OBSERVABILITY_SERVICE_NAME=blitzpay-mobile
EXPO_PUBLIC_OBSERVABILITY_SERVICE_VERSION=1.0.0
EXPO_PUBLIC_OBSERVABILITY_INGEST_PATH=/api/observability/mobile-logs
EXPO_PUBLIC_OBSERVABILITY_SAMPLE_RATE=1
EXPO_PUBLIC_OBSERVABILITY_CAPTURE_CONSOLE=true