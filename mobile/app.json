{
  "expo": {
    "name": "BlitzPay",
    "slug": "blitzpay-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splashscreen_logo.png",
      "backgroundColor": "#000000",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.blitzpay.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan QR codes for payments",
        "NSFaceIDUsageDescription": "Used for biometric authentication"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "splash": {
        "image": "./assets/splashscreen_logo.png",
        "backgroundColor": "#000000",
        "resizeMode": "contain"
      },
      "package": "app.blitzpay.mobile",
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splashscreen_logo.png",
          "backgroundColor": "#000000",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow BlitzPay to access your camera to scan QR codes."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow BlitzPay to use Face ID for authentication."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "283f0dd6-d7d4-4dcc-8613-66621b812e7f"
      }
    },
    "owner": "m.mohammadi"
  }
}
